# Skopiuj do .env i uzupełnij. .env jest w .gitignore — nigdy nie commituj kluczy.

# YouTube Data API v3 — https://console.cloud.google.com/apis/credentials
YOUTUBE_API_KEY=

# Anthropic — https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=

# Telegram — token od @BotFather, chat_id np. z @userinfobot
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Publiczny URL strony (GitHub Pages), używany w wiadomości Telegram
SITE_URL=https://TWOJ-LOGIN.github.io/yt-brief

# Proxy rezydencjalny do transkrypcji — POTRZEBNY na GitHub Actions (chmura),
# bo YouTube blokuje pobieranie napisów z datacenter IP. Lokalnie NIEpotrzebny.
# Webshare: https://www.webshare.io -> Residential proxy -> Proxy Settings -> username/password.
WEBSHARE_PROXY_USERNAME=
WEBSHARE_PROXY_PASSWORD=
# Alternatywnie dowolny inny proxy (zamiast Webshare):
# YT_PROXY_URL=http://user:pass@host:port
