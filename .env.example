# Skopiuj do .env i uzupełnij. .env jest w .gitignore — nigdy nie commituj kluczy.

# YouTube Data API v3 — https://console.cloud.google.com/apis/credentials
YOUTUBE_API_KEY=

# Anthropic — https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=

# Telegram — token od @BotFather, chat_id np. z @userinfobot
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Publiczny URL strony (GitHub Pages), używany w wiadomości Telegram
SITE_URL=https://TWOJ-LOGIN.github.io/yt-brief
